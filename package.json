{
  "name": "@liangjie559567/ultrapower",
  "version": "7.5.2",
  "description": "Disciplined multi-agent orchestration: workflow enforcement + parallel execution",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "ultrapower": "dist/cli/index.js",
    "omc": "dist/cli/index.js",
    "omc-analytics": "dist/cli/analytics.js",
    "omc-cli": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "agents",
    "bridge",
    "bridge/mcp-server.cjs",
    "bridge/codex-server.cjs",
    "bridge/gemini-server.cjs",
    "bridge/team-bridge.cjs",
    "commands",
    "hooks",
    "scripts",
    "skills",
    "templates",
    "docs",
    ".claude-plugin/plugin.json",
    ".claude-plugin/marketplace.json",
    ".mcp.json",
    "settings.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && node scripts/parallel-build.mjs && npm run compose-docs",
    "build:bridge": "node scripts/build-skill-bridge.mjs",
    "build:codex": "node scripts/build-codex-server.mjs",
    "build:gemini": "node scripts/build-gemini-server.mjs",
    "build:bridge-entry": "node scripts/build-bridge-entry.mjs",
    "compose-docs": "node scripts/compose-docs.mjs",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:quick": "vitest run --config vitest.config.quick.ts --reporter=dot",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "format": "prettier --write src/**/*.ts",
    "sync-metadata": "tsx scripts/sync-metadata.ts",
    "sync-metadata:verify": "tsx scripts/sync-metadata.ts --verify",
    "sync-metadata:dry-run": "tsx scripts/sync-metadata.ts --dry-run",
    "prepare": "npm run build",
    "preversion": "npm run validate:versions",
    "prepublishOnly": "npm run validate:versions && npm run build && npm run compose-docs && npm run validate:skills && npm run sync:marketplace",
    "postinstall": "node scripts/plugin-setup.mjs",
    "release:local": "node scripts/release-local.mjs",
    "release:dry-run": "node scripts/release-local.mjs --dry-run",
    "bump": "node scripts/bump-version.mjs",
    "validate:versions": "node scripts/validate-versions.mjs",
    "sync:version": "node scripts/sync-version.mjs",
    "sync:version:dry": "node scripts/sync-version.mjs --dry-run",
    "sync:marketplace": "node scripts/sync-marketplace.mjs",
    "changeset": "changeset",
    "version": "changeset version && npm run sync:version && npm run sync:marketplace",
    "release": "npm run build && npm test && changeset publish",
    "validate:counts": "node scripts/validate-counts.mjs",
    "validate:counts:fix": "node scripts/validate-counts.mjs --fix",
    "check:links": "node scripts/check-links.mjs",
    "check:links:fix": "node scripts/check-links.mjs --fix",
    "validate:plugins": "node scripts/validate-plugin-configs.mjs",
    "validate:skills": "node scripts/validate-skill-frontmatter.mjs"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "@ast-grep/napi": "^0.41.1",
    "@modelcontextprotocol/sdk": "1.27.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@opentelemetry/sdk-trace-node": "^2.6.0",
    "@tokscale/core": "^1.0.25",
    "@types/better-sqlite3": "^7.6.13",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "ajv": "^8.17.1",
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.3.0",
    "commander": "^14.0.3",
    "express-rate-limit": "^7.5.0",
    "jsonc-parser": "^3.3.1",
    "safe-regex": "^2.1.1",
    "typescript-eslint": "^8.57.0",
    "vscode-languageserver-protocol": "^3.17.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^9.39.2",
    "@types/node": "22.19.15",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "esbuild": "^0.27.4",
    "eslint": "9.39.4",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.0",
    "ws": "^8.19.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liangjie559567/ultrapower.git"
  },
  "homepage": "https://github.com/liangjie559567/ultrapower#readme",
  "bugs": {
    "url": "https://github.com/liangjie559567/ultrapower/issues"
  },
  "author": "liangjie559567",
  "license": "MIT",
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "agent",
    "multi-agent",
    "orchestration",
    "omc",
    "claudecode",
    "anthropic",
    "llm"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": false
  }
}
